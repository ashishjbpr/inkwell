# Postgres connection string (e.g. from Neon)
DATABASE_URL=

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials)
# Authorized redirect URI: <origin>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret for next-auth session/JWT signing (e.g. `openssl rand -base64 32`)
NEXTAUTH_SECRET=

# Base URL of the app (used by next-auth for callbacks)
NEXTAUTH_URL=http://localhost:3000
